generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DeadlineType {
  BOLLO
  REVISIONE
  ASSICURAZIONE
}

enum VehicleType {
  AUTO
  MOTO
  CAMPER
}

enum FuelType {
  BENZINA
  DIESEL
  GPL
  METANO
  ELETTRICO
  IBRIDO_BENZINA
  IBRIDO_DIESEL
}

enum VehicleStatus {
  ATTIVO
  VENDUTO
  ROTTAMATO
}

enum ExpenseCategory {
  RIFORNIMENTO
  MANUTENZIONE
  ASSICURAZIONE
  BOLLO
  MULTA
  PARCHEGGIO
  LAVAGGIO
  PEDAGGI
  ALTRO
}

enum RegionalFuelType {
  BENZINA
  GASOLIO
  GPL
  METANO
}

enum FuelServiceType {
  SELF
  SERVITO
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  currency     String     @default("EUR")
  fuelPriceRegion String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  sessions     Session[]
  vehicles     Vehicle[]
  drivers      Driver[]
}

model Session {
  id        String   @id
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Vehicle {
  id         String         @id @default(cuid())
  userId     String
  plate      String
  make       String?
  model      String?
  modelDetail String?
  odometerKm Int?
  type       VehicleType    @default(AUTO)
  fuelType   FuelType?
  firstRegistrationDate DateTime?
  powerKw    Float?
  powerHp    Float?
  cubicCapacity Int?
  alarmSystemType String?
  listPriceAmount Float?
  listPriceCurrency String?
  environmentalClass String?
  insuranceCompany String?
  insurancePolicyNumber String?
  insurancePresent Boolean?
  insuranceSuspended Boolean?
  insuranceCompartmentExpiry DateTime?
  status     VehicleStatus  @default(ATTIVO)
  soldDate   DateTime?
  soldPrice  Float?
  soldNotes  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?
  user       User           @relation(fields: [userId], references: [id])
  deadlines  Deadline[]
  refuels    Refuel[]
  expenses   Expense[]
  drivers    VehicleDriver[]

  @@index([userId])
  @@index([plate])
  @@index([status])
}

model Deadline {
  id        String       @id @default(cuid())
  vehicleId String
  type      DeadlineType
  dueDate   DateTime
  amount    Float?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
  vehicle   Vehicle      @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([type])
  @@index([dueDate])
  @@unique([vehicleId, type])
}

model Refuel {
  id              String    @id @default(cuid())
  vehicleId       String
  date            DateTime
  liters          Float?    // totale litri (benzina+GPL/metano o solo benzina/diesel)
  kwh             Float?    // per veicoli elettrici
  litersPrimary   Float?    // litri benzina (per GPL/Metano)
  litersSecondary Float?    // litri GPL o kg Metano
  amountEur       Float
  odometerKm      Int
  fuelType        FuelType
  pricePerLiter   Float?    // €/litro o €/kWh calcolato automaticamente
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([date])
}

model Expense {
  id          String           @id @default(cuid())
  vehicleId   String
  date        DateTime
  category    ExpenseCategory
  amountEur   Float
  odometerKm  Int?
  description String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  vehicle     Vehicle          @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([date])
  @@index([category])
}

model Driver {
  id              String          @id @default(cuid())
  userId          String
  name            String
  licenseExpiry   DateTime
  phone           String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  user            User            @relation(fields: [userId], references: [id])
  vehicles        VehicleDriver[]

  @@index([userId])
  @@index([licenseExpiry])
  @@index([name])
}

model VehicleDriver {
  id        String   @id @default(cuid())
  vehicleId String
  driverId  String
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  driver    Driver   @relation(fields: [driverId], references: [id])

  @@unique([vehicleId, driverId])
  @@index([vehicleId])
  @@index([driverId])
}

model FuelPriceSnapshot {
  id           String          @id @default(cuid())
  snapshotDate DateTime
  region       String
  fuelType     RegionalFuelType
  serviceType  FuelServiceType
  averagePrice Float?
  sourceUrl    String
  fetchedAt    DateTime        @default(now())
  createdAt    DateTime        @default(now())

  @@unique([snapshotDate, region, fuelType, serviceType])
  @@index([snapshotDate])
  @@index([region])
  @@index([fuelType])
}

model PlateLookupCache {
  id                                 String   @id @default(cuid())
  plate                              String   @unique
  provider                           String   @default("TUTTOTARGHE")
  sourceJobId                        String?
  requestedTypes                     Json?
  rawResult                          Json?
  detailsData                        Json?
  rcaData                            Json?
  theftData                          Json?
  environmentalData                  Json?
  newlylicensedData                  Json?
  inspectionsData                    Json?
  detailsLicensePlate                String?
  detailsBrand                       String?
  detailsModel                       String?
  detailsModelDetail                 String?
  detailsBuildYear                   Int?
  detailsFirstRegistrationDate       DateTime?
  detailsFuelType                    String?
  detailsVehicleType                 String?
  detailsPowerKw                     Float?
  detailsPowerHp                     Float?
  detailsCubicCapacity               Int?
  detailsPriceAmount                 Float?
  detailsPriceCurrency               String?
  detailsAlarmSystemType             String?
  rcaPlate                           String?
  rcaVehicleTypeDescription          String?
  rcaInsuranceCompany                String?
  rcaPolicyNumber                    String?
  rcaInsurancePresent                Boolean?
  rcaInsuranceSuspended              Boolean?
  rcaPolicyExpiry                    DateTime?
  rcaPolicyCompartmentExpiry         DateTime?
  environmentalLicensePlate          String?
  environmentalVehicleType           String?
  environmentalClass                 String?
  environmentalVehicleTypeDescription String?
  fetchedAt                          DateTime @default(now())
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt

  @@index([provider])
  @@index([fetchedAt])
}
