generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DeadlineType {
  BOLLO
  REVISIONE
  ASSICURAZIONE
}

enum VehicleType {
  AUTO
  MOTO
  CAMPER
}

enum FuelType {
  BENZINA
  DIESEL
  GPL
  METANO
  ELETTRICO
  IBRIDO_BENZINA
  IBRIDO_DIESEL
}

enum VehicleStatus {
  ATTIVO
  VENDUTO
  ROTTAMATO
}

enum ExpenseCategory {
  RIFORNIMENTO
  MANUTENZIONE
  ASSICURAZIONE
  BOLLO
  MULTA
  PARCHEGGIO
  LAVAGGIO
  PEDAGGI
  ALTRO
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  currency     String     @default("EUR")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  sessions     Session[]
  vehicles     Vehicle[]
}

model Session {
  id        String   @id
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Vehicle {
  id         String         @id @default(cuid())
  userId     String
  plate      String
  make       String?
  model      String?
  odometerKm Int?
  type       VehicleType    @default(AUTO)
  fuelType   FuelType?
  year       Int?
  status     VehicleStatus  @default(ATTIVO)
  soldDate   DateTime?
  soldPrice  Float?
  soldNotes  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?
  user       User           @relation(fields: [userId], references: [id])
  deadlines  Deadline[]
  refuels    Refuel[]
  expenses   Expense[]

  @@index([userId])
  @@index([plate])
  @@index([status])
}

model Deadline {
  id        String       @id @default(cuid())
  vehicleId String
  type      DeadlineType
  dueDate   DateTime
  amount    Float?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
  vehicle   Vehicle      @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([type])
  @@index([dueDate])
  @@unique([vehicleId, type])
}

model Refuel {
  id              String    @id @default(cuid())
  vehicleId       String
  date            DateTime
  liters          Float?    // totale litri (benzina+GPL/metano o solo benzina/diesel)
  kwh             Float?    // per veicoli elettrici
  litersPrimary   Float?    // litri benzina (per GPL/Metano)
  litersSecondary Float?    // litri GPL o kg Metano
  amountEur       Float
  odometerKm      Int
  fuelType        FuelType
  pricePerLiter   Float?    // €/litro o €/kWh calcolato automaticamente
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([date])
}

model Expense {
  id          String           @id @default(cuid())
  vehicleId   String
  date        DateTime
  category    ExpenseCategory
  amountEur   Float
  odometerKm  Int?
  description String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  vehicle     Vehicle          @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([date])
  @@index([category])
}
